# ════════════════════════════════════════════════
#   MEME COIN BOT — Variables d'environnement
#   Copiez ce fichier en .env et remplissez les valeurs
# ════════════════════════════════════════════════

# ── TELEGRAM (obligatoire) ────────────────────────────────────────────────────
# 1. Ouvrez Telegram, cherchez @BotFather
# 2. Envoyez /newbot, donnez un nom et un username
# 3. Copiez le token ici
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# 4. Pour votre Chat ID: envoyez un message à votre bot,
#    puis visitez https://api.telegram.org/bot<TOKEN>/getUpdates
#    et trouvez "chat":{"id": VOTRE_ID}
TELEGRAM_CHAT_ID=123456789

# ── TRADING ────────────────────────────────────────────────────────────────────
# "paper" = simulation (recommandé pour commencer)
# "live"  = trading réel (nécessite SOLANA_PRIVATE_KEY)
TRADING_MODE=paper

# Portfolio simulé en paper trading (USD)
INITIAL_PORTFOLIO=1000

# Taille de chaque position (% du portfolio)
POSITION_SIZE_PCT=0.05

# Nombre maximum de positions ouvertes simultanément
MAX_OPEN_POSITIONS=5

# Stop Loss (ex: 0.15 = -15%)
STOP_LOSS_PCT=0.15

# Take Profit (ex: 0.50 = +50%)
TAKE_PROFIT_PCT=0.50

# Fermeture automatique après N heures
MAX_HOLD_HOURS=48

# ── SCANNER ────────────────────────────────────────────────────────────────────
# Intervalle de scan en secondes (300 = 5 minutes)
SCAN_INTERVAL_SECONDS=300

# Liquidité minimale en USD
MIN_LIQUIDITY_USD=10000

# Volume 24h minimum en USD
MIN_VOLUME_24H_USD=5000

# Âge minimum du token en heures (24 = 1 jour minimum)
MIN_AGE_HOURS=24

# Âge maximum du token en heures (168 = 7 jours)
MAX_AGE_HOURS=168

# Variation de prix minimale sur 1h pour être considéré (%)
MIN_PRICE_CHANGE_1H=2

# Variation de prix minimale sur 24h (%)
MIN_PRICE_CHANGE_24H=10

# ── IA / ML ────────────────────────────────────────────────────────────────────
# Score minimum pour ouvrir un trade (0-100)
MIN_SCORE_TO_TRADE=70

# Fréquence de réentraînement du modèle (jours)
RETRAIN_INTERVAL_DAYS=7

# Nombre minimum de trades pour démarrer l'entraînement ML
MIN_TRADES_FOR_RETRAIN=20

# ── RAPPORT ────────────────────────────────────────────────────────────────────
# Heure UTC d'envoi du rapport quotidien (8 = 08:00 UTC)
REPORT_HOUR_UTC=8

# ── CHAINS CIBLES ─────────────────────────────────────────────────────────────
# Séparées par virgule: solana,bsc,eth
TARGET_CHAINS=solana

# ── LIVE TRADING — SOLANA (désactivé par défaut) ─────────────────────────────
# ⚠️  NE REMPLISSEZ PAS CECI TANT QUE VOUS N'AVEZ PAS TESTÉ EN PAPER TRADING
# Clé privée du wallet dédié (format base58)
# SOLANA_PRIVATE_KEY=

# Slippage en basis points (100 = 1%)
JUPITER_SLIPPAGE_BPS=100
